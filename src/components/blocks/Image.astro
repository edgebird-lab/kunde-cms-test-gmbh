---
import {
  ctaHref,
  ctaTarget,
  ctaRel,
  ctaHrefWithPreview,
  ctaTargetWithPreview,
  ctaRelWithPreview,
  type ActionLike,
  type PreviewLinkContext,
} from "../../lib/cta.ts";
export interface Props {
  src?: string|null;
  alt?: string;
  fit?: 'cover'|'contain';
  ratio?: '16:9'|'4:3'|'3:2'|'1:1'|'original';
  link?: ActionLike | null;
  previewLinkContext?: PreviewLinkContext | null;
}
const { src, alt = '', fit = 'cover', ratio = 'original', link = null, previewLinkContext = null } = Astro.props;
const pctx = previewLinkContext;
const ratioClass = ratio === '16:9' ? 'r-16-9' : ratio === '4:3' ? 'r-4-3' : ratio === '3:2' ? 'r-3-2' : ratio === '1:1' ? 'r-1-1' : 'r-org';
const Inner = src
  ? `<img src="${src}" alt="${alt.replace(/"/g, '&quot;')}" loading="lazy" class="blk-img-el" data-fit="${fit}" />`
  : `<div class="blk-img-placeholder" aria-hidden="true">BILD</div>`;
const linkable = !!(link && link.target);
---
{linkable ? (
  <a href={pctx ? ctaHrefWithPreview(link, pctx) : ctaHref(link)} target={pctx ? ctaTargetWithPreview(link, pctx) : ctaTarget(link)} rel={pctx ? ctaRelWithPreview(link, pctx) : ctaRel(link)} class={`blk-img ${ratioClass}`}>
    <Fragment set:html={Inner} />
  </a>
) : (
  <div class={`blk-img ${ratioClass}`}>
    <Fragment set:html={Inner} />
  </div>
)}
<style>
  .blk-img { display: block; width: 100%; overflow: hidden; border-radius: var(--radius); }
  .blk-img.r-16-9 { aspect-ratio: 16 / 9; }
  .blk-img.r-4-3  { aspect-ratio: 4 / 3; }
  .blk-img.r-3-2  { aspect-ratio: 3 / 2; }
  .blk-img.r-1-1  { aspect-ratio: 1 / 1; }
  .blk-img :global(.blk-img-el) { width: 100%; height: 100%; display: block; }
  .blk-img :global(.blk-img-el[data-fit="cover"]) { object-fit: cover; }
  .blk-img :global(.blk-img-el[data-fit="contain"]) { object-fit: contain; background: var(--bg2); }
  .blk-img :global(.blk-img-placeholder) {
    width: 100%; min-height: 200px; aspect-ratio: 4 / 3;
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); font-size: var(--fs-sm); font-weight: 700; letter-spacing: .12em;
    border: 2px dashed color-mix(in srgb, var(--accent) 50%, transparent);
    background: var(--bg2);
  }
</style>
